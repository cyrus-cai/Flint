{
  "name": "flint-mcp",
  "version": "0.9.11",
  "private": true,
  "packageManager": "bun@1.3.3",
  "description": "MCP server exposing Flint note operations over stdio.",
  "type": "module",
  "main": "./dist/server.mjs",
  "bin": {
    "flint-mcp": "./dist/server.mjs"
  },
  "scripts": {
    "build": "esbuild src/server.ts --bundle --platform=node --format=esm --target=node18 --outfile=dist/server.mjs --banner:js='#!/usr/bin/env node' && chmod +x dist/server.mjs",
    "start": "node dist/server.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1"
  },
  "devDependencies": {
    "esbuild": "^0.25.12"
  }
}
